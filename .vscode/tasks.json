{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "MNWork: Démarrer le serveur",
      "type": "shell",
      "command": "node server.js",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PATH": "C:\\Program Files\\nodejs;${env:LOCALAPPDATA}\\Programs\\node;${env:PATH}"
        }
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "focus": true
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "MNWork: Lancer (serveur + tunnel, comme launch.bat)",
      "type": "shell",
      "command": "cmd /c launch.bat",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PATH": "C:\\Program Files\\nodejs;${env:LOCALAPPDATA}\\Programs\\node;${env:PATH}"
        }
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    }
  ]
}
